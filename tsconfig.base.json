{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@greyfield/audio-runtime": ["packages/audio-runtime/src/index.ts"],
      "@greyfield/core-runtime": ["packages/core-runtime/src/index.ts"],
      "@greyfield/persistence/config-schema": ["packages/persistence/src/config-schema.ts"],
      "@greyfield/persistence": ["packages/persistence/src/index.ts"],
      "@greyfield/stage-live2d": ["packages/stage-live2d/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM"]
  }
}

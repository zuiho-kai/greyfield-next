{
  "name": "@greyfield/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:live2d": "node scripts/dev-live2d-electron.mjs",
    "dev:shell-plan": "tsx src/main/dev-placeholder.ts",
    "dev:electron": "pnpm build:main && electron dist-main/index.mjs",
    "build": "vite build",
    "build:main": "node scripts/build-main.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build:all": "pnpm build && pnpm build:preload && pnpm build:main",
    "ensure:electron": "node scripts/ensure-electron-binary.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@greyfield/audio-runtime": "workspace:*",
    "@greyfield/core-runtime": "workspace:*",
    "@greyfield/persistence": "workspace:*",
    "@greyfield/stage-live2d": "workspace:*",
    "live2dcubismcore": "1.0.2",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "^42.2.0",
    "esbuild": "^0.28.0",
    "vite": "^8.0.14"
  }
}

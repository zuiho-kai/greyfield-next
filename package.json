{
  "name": "greyfield-next",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"packages/dev-harness/src/**\"",
    "test:backend": "vitest run packages/core-runtime packages/audio-runtime packages/persistence apps/desktop/src/main",
    "test:frontend": "vitest run apps/desktop/src/renderer apps/desktop/src/preload packages/stage-live2d packages/dev-harness",
    "test:changed": "vitest related --run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build:desktop": "pnpm --filter @greyfield/desktop build:all",
    "harness:acceptance": "tsx packages/dev-harness/src/acceptance.ts",
    "harness:v1-visual": "pnpm build:desktop && tsx packages/dev-harness/src/v1-visual-acceptance-check.ts",
    "harness:fallback": "tsx packages/dev-harness/src/fallback-check.ts",
    "harness:live2d": "tsx packages/dev-harness/src/live2d-check.ts",
    "harness:electron": "pnpm build:desktop && tsx packages/dev-harness/src/electron-check.ts",
    "harness:electron:quick": "tsx packages/dev-harness/src/electron-check.ts",
    "harness:electron:restart-context": "pnpm build:desktop && tsx packages/dev-harness/src/electron-restart-context-check.ts",
    "harness:electron:real-llm": "pnpm build:desktop && tsx packages/dev-harness/src/electron-real-llm-check.ts",
    "harness:electron:provider-failure": "pnpm build:desktop && tsx packages/dev-harness/src/electron-provider-failure-check.ts",
    "harness:electron:provider-abort": "pnpm build:desktop && tsx packages/dev-harness/src/electron-provider-abort-check.ts",
    "harness:electron:stop-audio": "pnpm build:desktop && tsx packages/dev-harness/src/electron-stop-audio-check.ts",
    "harness:electron:bubble-long-reply": "pnpm build:desktop && tsx packages/dev-harness/src/electron-bubble-long-reply-check.ts",
    "harness:electron:bubble-edge-clickthrough": "pnpm build:desktop && tsx packages/dev-harness/src/electron-bubble-edge-clickthrough-check.ts",
    "harness:electron:settings-provider-test": "pnpm build:desktop && tsx packages/dev-harness/src/electron-settings-provider-test-check.ts",
    "harness:electron:settings-active-chat-test": "pnpm build:desktop && tsx packages/dev-harness/src/electron-settings-active-chat-test-check.ts",
    "harness:real-tts": "tsx packages/dev-harness/src/real-tts-check.ts",
    "harness:electron:real-tts": "pnpm build:desktop && tsx packages/dev-harness/src/electron-real-tts-check.ts",
    "harness:electron:voice-input": "pnpm build:desktop && tsx packages/dev-harness/src/electron-voice-input-check.ts",
    "harness:electron:memory-summary": "pnpm build:desktop && tsx packages/dev-harness/src/electron-memory-summary-check.ts",
    "harness:electron:memory-control": "pnpm build:desktop && tsx packages/dev-harness/src/electron-memory-control-check.ts",
    "harness:electron:memory-atom-library": "pnpm build:desktop && tsx packages/dev-harness/src/electron-memory-atom-library-check.ts",
    "harness:electron:visual-observation": "pnpm build:desktop && tsx packages/dev-harness/src/electron-visual-observation-check.ts",
    "harness:electron:proactive-desktop-message": "pnpm build:desktop && tsx packages/dev-harness/src/electron-proactive-desktop-message-check.ts",
    "harness:electron:single-persona-editor": "pnpm build:desktop && tsx packages/dev-harness/src/electron-single-persona-editor-check.ts",
    "harness:memory-benchmark": "tsx packages/dev-harness/src/memory-benchmark.ts",
    "harness:frontend-smoke": "tsx packages/dev-harness/src/frontend-full-check.ts --profile smoke",
    "harness:frontend-visual": "tsx packages/dev-harness/src/frontend-full-check.ts --profile visual",
    "harness:frontend-user-path": "tsx packages/dev-harness/src/frontend-full-check.ts --profile user-path",
    "harness:frontend-heavy": "tsx packages/dev-harness/src/frontend-full-check.ts --profile heavy",
    "harness:frontend-full": "tsx packages/dev-harness/src/frontend-full-check.ts",
    "harness:pet:quick": "tsx packages/dev-harness/src/electron-check.ts --quick",
    "dev:live2d": "node apps/desktop/scripts/dev-live2d-electron.mjs",
    "dev:live2d:fast": "node apps/desktop/scripts/dev-live2d-electron.mjs --skip-build",
    "dev:live2d:rebuild": "node apps/desktop/scripts/dev-live2d-electron.mjs --force-build",
    "dev:live2d:stop": "node apps/desktop/scripts/stop-live2d-electron.mjs",
    "dev:live2d:url": "tsx packages/dev-harness/src/dev-live2d-url.ts",
    "dev": "pnpm --filter @greyfield/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "playwright": "^1.60.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
